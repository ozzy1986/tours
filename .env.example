# Root .env shared across local dev workflows (Laragon + Docker).
# Copy to .env and adjust if needed. Per-app .env files live in apps/api/.env and apps/web/.env.

# --- PostgreSQL ---
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=tours
DB_USERNAME=postgres
DB_PASSWORD=root

# --- URLs (Laragon defaults) ---
APP_URL=http://localhost:8000
API_URL=http://localhost:8000
WEB_URL=http://localhost:3000
EMBEDDINGS_URL=http://localhost:8001

# --- Embeddings service ---
EMBEDDINGS_MODEL=intfloat/multilingual-e5-small
EMBEDDINGS_DIM=384

# --- Yandex Maps (apps/web — Vike client env, see https://vike.dev/env) ---
# Get a JS API key at https://developer.tech.yandex.ru/
# Set in apps/web/.env (not root .env):
# PUBLIC_ENV__PUBLIC_YANDEX_MAPS_API_KEY=

# --- LLM (fallback for dev/CI; runtime values are stored encrypted in DB via admin UI) ---
LLM_PROVIDER=openai
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.7
