# syntax=docker/dockerfile:1
# dev: hot-reload Vike dev server (compose default `web` service)
# production: built assets + `vike preview` (compose `--profile production` → `web-prod`)

FROM node:22-alpine AS dev

WORKDIR /app

COPY package*.json ./
RUN npm ci --no-audit --no-fund

COPY . .

EXPOSE 3000
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]

FROM node:22-alpine AS build

WORKDIR /app

COPY package*.json ./
RUN npm ci --no-audit --no-fund

COPY . .

ARG PUBLIC_ENV__PUBLIC_API_URL=http://localhost:8000
ENV PUBLIC_ENV__PUBLIC_API_URL=${PUBLIC_ENV__PUBLIC_API_URL}

RUN npm run build

FROM node:22-alpine AS production

WORKDIR /app

COPY package*.json ./
RUN npm ci --no-audit --no-fund

COPY --from=build /app/dist ./dist
COPY --from=build /app/public ./public
COPY --from=build /app/pages ./pages
COPY --from=build /app/components ./components
COPY --from=build /app/lib ./lib
COPY --from=build /app/assets ./assets
COPY --from=build /app/vite.config.ts ./vite.config.ts
COPY --from=build /app/tsconfig.json ./tsconfig.json
COPY --from=build /app/env.d.ts ./env.d.ts
COPY --from=build /app/index.html ./index.html

EXPOSE 3000
CMD ["npm", "run", "preview", "--", "--host", "0.0.0.0"]
