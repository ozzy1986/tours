# Copy to apps/web/.env — Vite exposes only PUBLIC_* to the client.

# Laravel API (SSR + browser)
PUBLIC_ENV__PUBLIC_API_URL=http://127.0.0.1:8000

# Yandex Maps JS API 3 — «JavaScript API и HTTP Геокодер»
# Referer must include localhost; open the site at http://localhost:3000
PUBLIC_ENV__PUBLIC_YANDEX_MAPS_API_KEY=your-javascript-api-key

# Optional: «Матрица расстояний и построения маршрута» for pedestrian routes
PUBLIC_ENV__PUBLIC_YANDEX_MAPS_ROUTER_KEY=your-router-api-key
