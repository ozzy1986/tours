# Local bundled model (no internet after scripts/install-local-model.ps1).
MODEL_ID=models/intfloat-multilingual-e5-small
# Remote fallback: MODEL_ID=intfloat/multilingual-e5-small
EMBEDDING_DIM=384
HOST=0.0.0.0
PORT=8001
# true = offline hash stub. false = real E5 from MODEL_ID path or HuggingFace.
USE_STUB=false
# Optional; when set, POST /embed requires X-Api-Key header (apps/api EMBEDDINGS_API_KEY)
EMBEDDINGS_API_KEY=
